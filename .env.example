# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored, so your secrets stay local.

# Ollama server URL. Local: http://localhost:11434
# docker-compose: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# Models (must be pulled on the Ollama server first):
#   ollama pull llama3
#   ollama pull nomic-embed-text
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# Optional
# FLASK_SECRET_KEY=set-a-long-random-string-in-production
